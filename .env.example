# Copy to .env.local. Never commit the real key.
ALPHA_VANTAGE_API_KEY=replace_me

# Optional comma-separated override. Omit to use pipeline/config/advisor_universe.json (120 stocks).
# ADVISOR_SYMBOLS=AAPL,MSFT,GOOGL

# Alpha Vantage enriches at most five; the entire universe still gets scored.
ALPHA_ENRICH_LIMIT=5
