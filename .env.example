# Copy to .env.local. Never commit the real key.
ALPHA_VANTAGE_API_KEY=replace_me

# Optional comma-separated candidate universe. The output keeps the top 20.
ADVISOR_SYMBOLS=AAPL,MSFT,GOOGL,AMZN,META,NVDA,AVGO,ORCL,CRM,ADBE,JPM,BAC,GS,V,MA,JNJ,UNH,LLY,MRK,ABBV,WMT,COST,HD,MCD,NKE,XOM,CVX,CAT,GE,NEE,KO,PEP,PG,PM,TMO,ABT,DHR,LIN,HON,UPS,LOW,SBUX,DIS,NFLX,AMD,QCOM,TXN,AMAT,COP,SLB

# Alpha Vantage enriches at most five; the entire universe still gets scored.
ALPHA_ENRICH_LIMIT=5
