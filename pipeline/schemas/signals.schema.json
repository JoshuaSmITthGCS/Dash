{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["generated_at", "data_mode", "count", "hot_sectors", "signals", "cooling"],
  "properties": {
    "generated_at": {"type": "string", "format": "date-time"},
    "data_mode": {"enum": ["demo", "live"]},
    "count": {"type": "integer", "minimum": 0},
    "hot_sectors": {"type": "object"},
    "signals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ticker", "political_score", "breakdown", "label", "valuation_score", "fundamental_categories", "fundamental_coverage", "price_to_book", "return_on_equity", "free_cash_flow_yield", "debt_to_equity", "current_ratio"],
        "properties": {
          "ticker": {"type": "string", "pattern": "^[A-Z0-9.-]+$"},
          "political_score": {"type": "number", "minimum": 0, "maximum": 100},
          "valuation_score": {"type": ["number", "null"], "minimum": 0, "maximum": 100},
          "fundamental_categories": {"type": "object"},
          "fundamental_coverage": {"type": "number", "minimum": 0, "maximum": 1},
          "price_to_book": {"type": ["number", "null"]},
          "return_on_equity": {"type": ["number", "null"]},
          "free_cash_flow_yield": {"type": ["number", "null"]},
          "debt_to_equity": {"type": ["number", "null"]},
          "current_ratio": {"type": ["number", "null"]},
          "breakdown": {"type": "object", "minProperties": 6},
          "label": {"enum": ["HIGH CONVICTION", "WATCH", "NEUTRAL", "LOW"]}
        }
      }
    },
    "cooling": {"type": "array"}
  }
}
