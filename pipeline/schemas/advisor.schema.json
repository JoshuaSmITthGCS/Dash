{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "generated_at", "data_mode", "count", "research", "market", "source_status", "disclaimer"],
  "properties": {
    "schema_version": { "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "data_mode": { "const": "live" },
    "count": { "type": "integer", "minimum": 1, "maximum": 20 },
    "universe_count": { "type": "integer", "minimum": 20 },
    "research": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": {
        "type": "object",
        "required": ["ticker", "name", "score", "stance", "confidence", "components", "strengths", "risks"],
        "properties": {
          "ticker": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "score": { "type": "number", "minimum": 0, "maximum": 100 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "stance": { "enum": ["ATTRACTIVE", "PROMISING", "MIXED", "CAUTION", "INSUFFICIENT DATA"] },
          "components": { "type": "object" },
          "strengths": { "type": "array", "items": { "type": "string" } },
          "risks": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "market": { "type": "object" },
    "source_status": { "type": "object" },
    "disclaimer": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": true
}
